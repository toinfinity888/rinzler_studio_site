{
  "name": "audit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib workers middleware.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:contract": "vitest run tests/contract",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local --conditions=react-server scripts/migrate.ts",
    "db:migrate:mysql-to-postgres": "tsx --env-file=.env.local --conditions=react-server scripts/migrate-mysql-to-postgres.ts",
    "db:seed:admin": "tsx --env-file=.env.local --conditions=react-server scripts/seed-admin.ts",
    "db:seed:vendors": "tsx --env-file=.env.local --conditions=react-server scripts/seed-vendor-db.ts",
    "db:seed:questionnaire": "tsx --env-file=.env.local --conditions=react-server scripts/seed-questionnaire.ts",
    "db:test-project": "tsx --env-file=.env.local --conditions=react-server scripts/create-test-project.ts",
    "workers:dev": "tsx --env-file=.env.local --conditions=react-server workers/run.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.654.0",
    "@aws-sdk/client-s3": "^3.654.0",
    "@aws-sdk/s3-request-presigner": "^3.654.0",
    "@deepgram/sdk": "^3.9.0",
    "@hookform/resolvers": "^5.2.2",
    "@node-rs/argon2": "^2.0.2",
    "bullmq": "^5.34.0",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.1",
    "lighthouse": "^12.4.0",
    "mysql2": "^3.22.3",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "playwright": "^1.59.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.75.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "testcontainers": "^10.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
